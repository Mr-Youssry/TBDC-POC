# Copy to .env and fill in the real values. Do NOT commit .env.

# Postgres connection string.
# Local dev (if needed): postgresql://postgres:postgres@localhost:5432/tbdc_poc
# Production (rafiq-dev): postgresql://tbdc_app:<password>@shared-postgres:5432/tbdc_poc
DATABASE_URL="postgresql://tbdc_app:password@shared-postgres:5432/tbdc_poc"

# NextAuth v5
AUTH_SECRET="replace-with-openssl-rand-hex-32"
AUTH_TRUST_HOST="true"

# Bootstrap admins — seeded only if the User table is empty.
BOOTSTRAP_ADMIN_EMAILS="korayem@ready4vc.com,youssry@ready4vc.com"
BOOTSTRAP_ADMIN_PASSWORD="POC@ready4vc"
